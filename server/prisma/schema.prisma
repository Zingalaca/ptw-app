// Prisma schema for PTW (Price to Win) application v2.0
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ClinType {
  LABOR
  PRODUCTION
  ODC
  NSP
}

enum ContractType {
  FFP
  CPFF
  CPIF
  FPIF
  COST
  TM
}

enum CostBasis {
  OFFEROR_PROPOSED
  GOVT_ESTIMATE
}

enum CompanyType {
  PUBLIC
  PRIVATE
}

// ─── Contract ────────────────────────────────────────────────────────────────
// A government solicitation / contract opportunity being analyzed for PTW
model Contract {
  id               Int          @id @default(autoincrement())
  contractNumber   String       @unique
  title            String
  agency           String
  description      String?
  naicsCode        String?
  setAside         String?      // e.g. "Full and Open", "SDVOSB", "8(a)"
  popStart         DateTime?    // Period of Performance start
  popEnd           DateTime?    // Period of Performance end
  status           String       @default("OPEN") // OPEN | AWARDED | CANCELLED
  baseYears        Int
  optionYears      Int
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  clins            Clin[]
  scenarios        Scenario[]
  competitors      Competitor[]
}

// ─── Clin ─────────────────────────────────────────────────────────────────────
// Contract Line Item Number — a discrete deliverable/task on the contract
model Clin {
  id                  Int      @id @default(autoincrement())
  contractId          Int
  clinNumber          String
  description         String
  clinType            ClinType
  contractType        ContractType
  optionYear          Int      @default(0)
  blockNumber         Int      @default(1)
  sampleTaskRef       String?
  govtHourCeiling     Float?
  totalHours          Float?
  primeSubkMix        Float    @default(1.0)
  quantity            Float?
  unitOfMeasure       String?
  isStepladder        Boolean  @default(false)
  govtEstimate        Float?
  govtProvidedODCs    Float?
  isSeparatelyPriced  Boolean  @default(true)
  feeAllowed          Boolean  @default(true)
  feeOnODCs           Boolean  @default(false)
  nteAmount           Float?
  realismFactorPct    Float?
  costBasis           CostBasis @default(OFFEROR_PROPOSED)
  isInTEP             Boolean   @default(true)

  contract            Contract  @relation(fields: [contractId], references: [id])
  tepResults          TepResult[]
  stepladderBreaks    StepladderBreak[]
}

// ─── Scenario ─────────────────────────────────────────────────────────────────
// A named PTW pricing scenario (e.g. "Base Case", "Conservative", "Optimistic")
model Scenario {
  id              Int              @id @default(autoincrement())
  contractId      Int
  name            String
  description     String?
  isBaseline      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  contract        Contract         @relation(fields: [contractId], references: [id])
  rateAssumptions RateAssumption[]
  tepResults      TepResult[]
}

// ─── Competitor ───────────────────────────────────────────────────────────────
// A company known or suspected to be bidding on the contract
model Competitor {
  id                Int         @id @default(autoincrement())
  contractId        Int
  name              String
  dunsNumber        String?
  gsaScheduleNumber String?
  historicalWinRate Float?      // 0.0 – 1.0 (percentage expressed as decimal)
  estimatedRevenue  Float?      // Annual revenue in millions USD
  strengths         String?
  weaknesses        String?
  likelyBidPrice    Float?      // Analyst's estimated total bid price
  companyType       CompanyType @default(PUBLIC)
  isOurCompany      Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  contract          Contract              @relation(fields: [contractId], references: [id])
  tepResults        TepResult[]
  rateProfile       CompetitorRateProfile?
}

// ─── RateAssumption ───────────────────────────────────────────────────────────
// Fully-burdened labor rate build-up for a specific labor category in a scenario
model RateAssumption {
  id                Int              @id @default(autoincrement())
  scenarioId        Int
  laborCategory     String           // e.g. "Program Manager", "Software Engineer"
  level             String?          // e.g. "Senior", "Mid", "Junior"
  baseRate          Float            // $/hour
  escalationRate    Float            @default(0.03)  // annual % (decimal)
  fringeRate        Float            // fringe benefit rate (decimal)
  overheadRate      Float            // overhead rate (decimal)
  gaRate            Float            // G&A rate (decimal)
  feeRate           Float            // profit / fee rate (decimal)
  wrappedRate       Float            // fully burdened $/hour
  geographicIndexId Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  scenario          Scenario         @relation(fields: [scenarioId], references: [id])
  geographicIndex   GeographicIndex? @relation(fields: [geographicIndexId], references: [id])
}

// ─── TepResult ────────────────────────────────────────────────────────────────
// Total Evaluated Price result for a competitor on a specific CLIN within a scenario
model TepResult {
  id                Int         @id @default(autoincrement())
  scenarioId        Int
  clinId            Int
  competitorId      Int?
  proposedCost      Float       @default(0)
  proposedFee       Float       @default(0)
  proposedTep       Float       @default(0)
  evaluatedTep      Float       @default(0)
  primeHours        Float?
  subkHours         Float?
  primeLaborCost    Float?
  subkLaborCost     Float?
  totalLaborCost    Float?
  indirectCost      Float?
  odcCost           Float?
  materialCost      Float?
  gaAmount          Float?
  feeAmount         Float?
  realismApplied    Boolean     @default(false)
  isNSP             Boolean     @default(false)
  notes             String?

  scenario          Scenario    @relation(fields: [scenarioId], references: [id])
  clin              Clin        @relation(fields: [clinId], references: [id])
  competitor        Competitor? @relation(fields: [competitorId], references: [id])
}

// ─── CompetitorRateProfile ────────────────────────────────────────────────────
// Company-level overhead/burden rate assumptions for a competitor (or own company)
model CompetitorRateProfile {
  id                    Int         @id @default(autoincrement())
  competitorId          Int         @unique
  contractId            Int
  primeCompositeRate    Float?
  subkCompositeRate     Float?
  primeSubkMix          Float?      @default(1.0)
  engOHRate             Float?
  mfgOHRate             Float?
  materialHandlingRate  Float?
  subkHandlingRate      Float?
  gaRate                Float?
  valueAddedGA          Boolean     @default(false)
  feeRate               Float?
  cpifTargetFee         Float?
  cpifMinFee            Float?
  cpifMaxFee            Float?
  fpifTargetFee         Float?
  fpifCeilingPrice      Float?
  engLocation           String?
  prodLocation          String?
  engGeoOffset          Float?
  prodGeoOffset         Float?
  fringeInOH            Boolean     @default(true)
  escalationRate        Float?
  notes                 String?

  competitor            Competitor  @relation(fields: [competitorId], references: [id])
}

// ─── StepladderBreak ──────────────────────────────────────────────────────────
// Price break points for stepladder-priced CLINs
model StepladderBreak {
  id              Int     @id @default(autoincrement())
  clinId          Int
  breakMin        Float
  breakMax        Float?
  unitPrice       Float
  mlqProbability  Float

  clin            Clin    @relation(fields: [clinId], references: [id])
}

// ─── GeographicIndex ──────────────────────────────────────────────────────────
// Geographic cost-of-labor index used to adjust base rates by location
model GeographicIndex {
  id              Int              @id @default(autoincrement())
  location        String           // City or region name
  state           String           // Two-letter state abbreviation
  msa             String?          // Metropolitan Statistical Area name
  index           Float            // Multiplier (1.0 = national average)
  source          String?          // Data source, e.g. "BLS", "ERI"
  effectiveYear   Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  rateAssumptions RateAssumption[]

  @@unique([location, effectiveYear])
}
