# Development — leave this file empty (or don't create .env at all).
# The Vite dev server proxies /api/* → http://localhost:3001 automatically.

# Production (Vercel) — set this in Vercel Project Settings → Environment Variables:
VITE_API_URL=https://your-backend.example.com

# The server's .env must also have:
# CLIENT_URL=https://your-app.vercel.app   (so CORS allows the Vercel origin)
